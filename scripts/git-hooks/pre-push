#!/usr/bin/env bash
# DEViLBOX pre-push — full gate (~125 s, deterministic).
#
# Push to `main` triggers Hetzner deploy + GitHub Actions. Block here
# before the slow remote path fails.
#
# Runs SERIALLY, fail-fast. The jobs used to run in parallel, but on an
# 8-core box type-check (tsc) and test:ci (vitest) EACH spawn ~8 worker
# threads — 16+ threads thrashing 8 cores oversubscribes the CPU so badly
# that a 65 s job can balloon past 5 min or hang. Those false timeouts were
# the "pushing takes forever" retries. Serial is slower on paper (~125 s vs
# a 65 s happy path) but deterministic and never retries, so it wins in
# practice. Fail-fast: type-check first (cheap signal), then the suites.
#
#   - `npm run type-check`      (tsc -b --force)   ~58 s
#   - `npm run test:ci`         (vitest)           ~65 s
#   - `npm run test:compliance` (tracker fx)       ~2 s
#
# Bypass in emergencies with `git push --no-verify`. Don't make a habit
# of it — this is the same gate CI runs.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

if [ -t 2 ]; then
  RED=$'\033[31m'; GRN=$'\033[32m'; YLW=$'\033[33m'; RST=$'\033[0m'
else
  RED=''; GRN=''; YLW=''; RST=''
fi

# Run one job; on failure print its captured log and abort the push.
run_step() {
  local name=$1; shift
  echo "${YLW}[pre-push] ${name}…${RST}" >&2
  local log; log="$(mktemp)"
  if "$@" > "$log" 2>&1; then
    echo "${GRN}[pre-push] ${name} ok${RST}" >&2
    rm -f "$log"
  else
    local code=$?
    echo "${RED}[pre-push] ${name} failed (exit ${code}):${RST}" >&2
    cat "$log" >&2
    rm -f "$log"
    echo "${RED}[pre-push] blocked — fix the failures above or push with --no-verify.${RST}" >&2
    exit 1
  fi
}

run_step "type-check"      npm run --silent type-check
run_step "test:ci"         npm run --silent test:ci
run_step "test:compliance" npm run --silent test:compliance

echo "${GRN}[pre-push] all checks passed${RST}" >&2
