CXX = {NATIVECXX}
# TODO: Fix command substition for pkg-config
CXXFLAGS = -W -Wall -O2 -g -std=c++11 $$(pkg-config --cflags sdl2)
LDFLAGS = -lm $$(pkg-config --libs sdl2)
EXES = write_audio
OBJECTS = main.o uadegl.o util.o sdl_mode.o

all:	$(EXES)

write_audio:    $(OBJECTS)
	$(CXX) $(CXXFLAGS) -o $@ $(OBJECTS) $(LDFLAGS)

%.o: %.cc
	$(CXX) $(CXXFLAGS) -c $<

uadegl.o:	uadegl.cc uadegl.h
sdl_mode.o:	sdl_mode.cc sdl_mode.h
util.o: util.cc util.h
main.o:	main.cc main.h

clean:
	rm -f $(EXES) *.o
